{
  "name": "@inheritbench/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.14.0 <23",
    "pnpm": "10.7.1"
  },
  "scripts": {
    "dev": "node --experimental-strip-types scripts/ingest-data.ts && next dev",
    "ingest": "node --experimental-strip-types scripts/ingest-data.ts",
    "project:reference": "node --experimental-strip-types scripts/project-reference-run.ts",
    "prebuild": "node --experimental-strip-types scripts/ingest-data.ts",
    "build": "next build --webpack",
    "start": "serve out -l 4173",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test e2e/local.spec.ts",
    "build-report": "node --experimental-strip-types scripts/write-build-report.ts",
    "verify-build-report": "node --experimental-strip-types scripts/write-build-report.ts --verify-portable"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-tabs": "1.1.17",
    "ajv": "8.20.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "geist": "1.7.2",
    "lucide-react": "1.24.0",
    "motion": "12.42.2",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "3.9.2",
    "tailwind-merge": "3.6.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "serve": "14.2.6",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
